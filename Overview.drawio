        <mxCell id="e0" value="05 — Escalation: Material request rejected 3+ times triggers escalation" style="text;html=1;align=center;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="80" y="20" width="1500" height="40" as="geometry"/></mxCell>
        <mxCell id="e0s" value="IN_PROGRESS → MATERIAL_REQUESTED ↔ (reject/retry cycle) → ESCALATED → IN_PROGRESS" style="text;html=1;align=center;fontSize=10;fontStyle=2;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="80" y="55" width="1500" height="24" as="geometry"/></mxCell>

        <mxCell id="e1" value="&lt;b&gt;IN_PROGRESS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="100" y="140" width="150" height="60" as="geometry"/></mxCell>
