        <mxCell id="e4" value="&lt;b&gt;IN_PROGRESS&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Resolved by different manager&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="910" y="140" width="180" height="60" as="geometry"/></mxCell>
