        <mxCell id="a9" value="&lt;b&gt;MAINTENANCE HISTORY&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Auto-appended to Machinery&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1"><mxGeometry x="1480" y="260" width="160" height="60" as="geometry"/></mxCell>
