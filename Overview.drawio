        <mxCell id="e2note" value="&lt;font style='font-size:9px'&gt;Manager rejects MR → rejectionCount++&lt;br&gt;Tech can submit new MR&lt;br&gt;Task stays MATERIAL_REQUESTED&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="330" y="250" width="180" height="80" as="geometry"/></mxCell>
