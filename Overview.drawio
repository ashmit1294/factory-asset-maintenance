        <mxCell id="t1" value="01 — Happy Path: Full lifecycle to confirmed resolution" style="text;html=1;align=center;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="100" y="20" width="1400" height="40" as="geometry"/></mxCell>
        <mxCell id="t1s" value="REPORTED → UNDER_REVIEW → ASSIGNED → IN_PROGRESS → [MATERIAL_REQUESTED → IN_PROGRESS] → COMPLETED → CONFIRMED" style="text;html=1;align=center;fontSize=10;fontStyle=2;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="100" y="55" width="1400" height="24" as="geometry"/></mxCell>

        <mxCell id="a1" value="&lt;b&gt;REPORTED&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;User reports issue&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="80" y="120" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="a2" value="&lt;b&gt;UNDER_REVIEW&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Manager reviews&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="280" y="120" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="a3" value="&lt;b&gt;ASSIGNED&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Manager assigns tech&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="480" y="120" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="a4" value="&lt;b&gt;IN_PROGRESS&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Technician starts work&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="680" y="120" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="a5" value="&lt;b&gt;MATERIAL_REQUESTED&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Technician requests parts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="830" y="260" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="a5b" value="&lt;b&gt;MR APPROVED&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Manager approves + inventory deducted (txn)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1060" y="260" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="a6" value="&lt;b&gt;IN_PROGRESS&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Work resumes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1080" y="120" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="a7" value="&lt;b&gt;COMPLETED&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Technician marks done&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1280" y="120" width="140" height="60" as="geometry"/></mxCell>
