{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production",
    "JWT_EXPIRES_IN": "8h",
    "BCRYPT_ROUNDS": "12",
    "ESCALATION_REJECTION_THRESHOLD": "3",
    "ESCALATION_AUTO_CANCEL_DAYS": "7"
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude).env*' ':(exclude)DEPLOYMENT.md'"
}
