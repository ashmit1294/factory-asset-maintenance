# Example environment variables
# Copy this to .env.local for development
# For production, set these in your deployment platform (Vercel, etc.)

# Database - Use MongoDB Atlas for production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/factory-asset-maintenance

# JWT Configuration - IMPORTANT: Change in production!
JWT_SECRET=your-super-secret-key-must-be-at-least-32-characters-long-change-this
JWT_EXPIRES_IN=8h

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Runtime Environment
NODE_ENV=development

# Business Rules
ESCALATION_REJECTION_THRESHOLD=3
ESCALATION_AUTO_CANCEL_DAYS=7

# Security
BCRYPT_ROUNDS=12

# Rate Limiting (optional - for Upstash Redis)
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
